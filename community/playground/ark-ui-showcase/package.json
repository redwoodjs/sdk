    "react-server-dom-webpack": "19.2.4",
    "rwsdk": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.30.0",
    "@cloudflare/workers-types": "4.20260317.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vite": "8.0.1",
    "vitest": "^4.1.0",
