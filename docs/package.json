{
  "name": "docs",
  "version": "1.0.0",
  "description": "RedwoodSDK Documentation",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "cd ../sdk && npx tsc --build --clean && npx tsc && cd ../docs && vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "pnpm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && pnpm run clean && pnpm run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types",
    "check": "pnpm run generate && pnpm run types && pnpm run lint && pnpm run fmt:check",
    "types": "tsc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@orama/orama": "^3.1.18",
    "@orama/plugin-qps": "^3.1.18",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.7.12",
    "fumadocs-mdx": "^14.2.7",
    "fumadocs-ui": "npm:@fumadocs/base-ui@latest",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-server-dom-webpack": "19.2.5",
    "rwsdk": "workspace:*",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.31.2",
    "@cloudflare/workers-types": "4.20260412.1",
    "@tailwindcss/typography": "^0.5.18",
    "@tailwindcss/vite": "^4.1.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "remark": "^15.0.1",
    "remark-mdx": "^3.1.1",
    "tailwindcss": "^4.1.13",
    "typescript": "6.0.2",
    "unist-util-visit": "^5.1.0",
    "vite": "~8.0.8",
    "wrangler": "4.81.1"
  },
  "pnpm": {}
}
