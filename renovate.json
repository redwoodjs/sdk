{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "ignorePresets": ["group:monorepos", "group:recommended"],
  "timezone": "UTC",
  "separateMajorMinor": false,
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "rangeStrategy": "bump",
  "groupName": "all-dependencies",
  "groupSlug": "all-dependencies",
  "updateNotScheduled": false,
  "packageRules": [
    {
      "description": "Critical Dependencies (Every Sunday)",
      "matchPackageNames": [
        "react",
        "react-dom",
        "react-server-dom-webpack",
        "@types/react",
        "@types/react-dom",
        "@cloudflare/vite-plugin",
        "@cloudflare/workers-types",
        "wrangler",
        "vite"
      ],
      "prPriority": 10,
      "ignoreUnstable": true,
      "schedule": ["every sunday"]
    },
    {
      "description": "SDK & Starter (Every 2 weeks on 1st/3rd Sunday)",
      "matchFileNames": ["sdk/package.json", "addons/**", "starter/package.json"],
      "excludePackageNames": [
        "react",
        "react-dom",
        "react-server-dom-webpack",
        "@types/react",
        "@types/react-dom",
        "@cloudflare/vite-plugin",
        "@cloudflare/workers-types",
        "wrangler",
        "vite"
      ],
      "schedule": ["* * 1-7 * 0", "* * 15-21 * 0"]
    },
    {
      "description": "Infrastructure, Playgrounds, Community, and all remaining files (Every 2 weeks on 2nd/4th Sunday)",
      "matchFileNames": [
        "**/*",
        "!sdk/package.json",
        "!addons/**",
        "!starter/package.json"
      ],
      "excludePackageNames": [
        "react",
        "react-dom",
        "react-server-dom-webpack",
        "@types/react",
        "@types/react-dom",
        "@cloudflare/vite-plugin",
        "@cloudflare/workers-types",
        "wrangler",
        "vite"
      ],
      "schedule": ["* * 8-14 * 0", "* * 22-28 * 0"]
    },
    {
      "description": "Force all updates into the single all-dependencies group (overrides any preset-injected groupName)",
      "matchPackageNames": ["*"],
      "groupName": "all-dependencies",
      "groupSlug": "all-dependencies"
    }
  ],
  "prHeader": " chore(deps): {{{prTitle}}}",
  "prBodyNotes": "This PR updates the following dependencies:\n\n{{{table}}}",
  "automerge": false,
  "major": {
    "automerge": false
  },
  "minor": {
    "automerge": false
  },
  "patch": {
    "automerge": false
  }
}
